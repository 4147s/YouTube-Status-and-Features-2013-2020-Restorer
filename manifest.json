{
  "manifest_version": 3,
  "name": "YouTube Status and Features 2013-2020 Restorer",
  "version": "1.0.0",
  "description": "Restore YouTube features and status indicators from 2013-2020, including copyright status, community guidelines, monetization, and more",
  "author": "Tom Leaman",
  "permissions": [
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "*://www.youtube.com/*",
    "*://youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://youtube.com/*"
      ],
      "js": [
        "background.js"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_icon": "icon.png",
    "default_title": "YouTube Status and Features 2013-2020 Restorer"
  }
}
